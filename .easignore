# EAS Build 用 ignore ファイル
# .gitignore と同じ内容だが、google-services.json は EAS Build に含める

# dependencies
node_modules/
package-lock.json

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# EAS local build artifacts
build-*.tar.gz
*.apk

# Firebase Admin SDK（クライアント用 google-services.json は含める）
*-firebase-adminsdk-*.json
