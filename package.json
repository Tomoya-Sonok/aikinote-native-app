{
  "name": "aikinote-native-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "start:prod": "EXPO_PUBLIC_WEB_URL=https://aikinote.com expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "check": "biome check .",
    "check:fix": "biome check . --write",
    "typecheck": "tsc --noEmit",
    "build:dev": "EXPO_NO_CAPABILITY_SYNC=1 eas build --profile development --platform all",
    "build:preview": "EXPO_NO_CAPABILITY_SYNC=1 eas build --profile preview --platform all",
    "build:prod": "EXPO_NO_CAPABILITY_SYNC=1 eas build --profile production --platform all",
    "submit": "eas submit --platform all",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.100.1",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "^55.0.10",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "^55.0.14",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "phosphor-react-native": "^3.0.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.14.0",
    "react-native-purchases-ui": "^9.14.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/react": "~19.1.0",
    "eas-cli": "^18.4.0",
    "husky": "^9.1.7",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "pnpm@8.15.4+sha256.cea6d0bdf2de3a0549582da3983c70c92ffc577ff4410cbf190817ddc35137c2"
}
